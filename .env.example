# ============================================================
# Variables de entorno — Sistema de Servicios Docentes UCO
# ============================================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env al repositorio (ya está en .gitignore).

# ------------------------------------------------------------
# Django — Configuracion general
# ------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=django-secret-key-placeholder-for-development
DJANGO_SECRET_KEY=django-secret-key-placeholder-for-development
DATABASE_URL=postgres://servicios_docentes:servicios_docentes@postgres:5432/sistema_servicios_docentes
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Opcional para revisar frontend local sin PostgreSQL. Produccion debe usar PostgreSQL.
USE_SQLITE=False

# ------------------------------------------------------------
# PostgreSQL 17
# ------------------------------------------------------------
POSTGRES_DB=sistema_servicios_docentes
POSTGRES_USER=servicios_docentes
POSTGRES_PASSWORD=servicios_docentes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Valkey 8 (broker Celery + cache + channel layer)
# ------------------------------------------------------------
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_URL=redis://valkey:6379/0
CELERY_BROKER_URL=redis://valkey:6379/0
CELERY_RESULT_BACKEND=redis://valkey:6379/0
CHANNEL_LAYERS_URL=redis://valkey:6379/0

# ------------------------------------------------------------
# JWT (djangorestframework-simplejwt)
# ------------------------------------------------------------
JWT_SECRET=jwt-secret-placeholder-for-development
JWT_SECRET_KEY=jwt-secret-placeholder-for-development
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# ------------------------------------------------------------
# reCAPTCHA v2/v3 (django-recaptcha)
# Obtén tus claves en: https://www.google.com/recaptcha/admin
# ------------------------------------------------------------
RECAPTCHA_PUBLIC_KEY=recaptcha-public-key-placeholder
RECAPTCHA_PRIVATE_KEY=recaptcha-private-key-placeholder

# ------------------------------------------------------------
# Nginx
# ------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_WEBSOCKET_PORT=8001

# ------------------------------------------------------------
# Daphne (servidor ASGI / WebSocket)
# ------------------------------------------------------------
DAPHNE_PORT=8001

# ------------------------------------------------------------
# Gunicorn (servidor WSGI / HTTP)
# ------------------------------------------------------------
GUNICORN_PORT=8000
GUNICORN_WORKERS=4

# ------------------------------------------------------------
# HashiCorp Vault (Key Vault — produccion)
# ------------------------------------------------------------
VAULT_ADDR=http://vault.internal:8200
VAULT_TOKEN=vault-token-placeholder

# ------------------------------------------------------------
# Observabilidad: Prometheus + Grafana
# ------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password-placeholder

# ------------------------------------------------------------
# Python / Docker
# ------------------------------------------------------------
PYTHONUNBUFFERED=1
